# --- Requeridas (el proceso muere si faltan) ---
ANTHROPIC_API_KEY=sk-ant-api03-...
API_URL=http://host.docker.internal:3001
API_TOKEN=token_del_api_aragon
ADMIN_NUMERO=521XXXXXXXXXX@c.us
BRIDGE_TOKEN=token_generado_con_generar-token.js
BRIDGE_URL=http://host.docker.internal:9999

# --- Servicios ---
CFO_URL=http://host.docker.internal:3002
WEB_URL=http://host.docker.internal:5000
FLASK_SERVICIO_NSSM=NombreServicioNSSM

# --- Rutas de repos en el servidor (para deteccion de commits) ---
RUTA_BOT=C:/path/to/tacos-aragon-bot
RUTA_API=C:/path/to/tacos-aragon-api
RUTA_CFO=C:/path/to/cfo-aragon-agent

# --- Umbrales ---
DISCO_MINIMO_GB=5
MEM_MINIMA_MB=512
INTERVALO_HEALTH_MS=30000
HEALTH_PORT=3000

# --- Base de datos ---
DB_PATH=/app/data/orchestrator.db
